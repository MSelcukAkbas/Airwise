{
  "name": "airwise-backend",
  "version": "1.0.0",
  "description": "Backend API for Airwise",
  "main": "src/index.ts",
  "scripts": {
    "dev": "npx tsx src/index.ts",
    "build": "esbuild src/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "db:push": "drizzle-kit push",
    "seed": "npx tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "express": "^5.0.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "drizzle-kit": "^0.31.4",
    "esbuild": "^0.27.3",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
